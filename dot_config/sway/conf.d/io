### Output configuration
#
# You can get the names of your outputs by running: swaymsg -t get_outputs

# set $bg bg #ff00ee solid_color
$mybind $mod+Ctrl+w exec ~/.local/bin/sway-bg-shuffler
exec --no-startup-id ~/.local/bin/sway-bg-shuffler
set $bg bg "$(cat /tmp/bg 2>/dev/null || echo './../../../../Media/wallpapers/core/black-haired-girl.jpg')" fill

output eDP-1 mode 2880x1800 scale 1.5 position 1707 0 $bg
output HDMI-A-1 mode 2560x1440 scale 1.5 position 0 0 $bg

### Input configuration
#
# You can get the names of your inputs by running: swaymsg -t get_inputs

input "1267:13016:ASUE120C:00_04F3:32D8_Touchpad" {
    dwt enabled
    tap enabled
    natural_scroll enabled
    middle_emulation enabled
    scroll_method two_finger
}

# input type:touchpad {
#     dwt enabled
#     tap enabled
#     natural_scroll disabled
#     middle_emulation enabled
# }
bindgesture swipe:3:up workspace prev
bindgesture swipe:3:left workspace prev
bindgesture swipe:3:down workspace next
bindgesture swipe:3:right workspace next
bindgesture swipe:4:up exec brightnessctl set 2%+
bindgesture swipe:4:down exec brightnessctl set 2%-
bindgesture pinch:3:inward exec $menu
bindgesture pinch:4:inward kill
bindgesture pinch:4:outward fullscreen
bindgesture hold:3 fullscreen

input type:keyboard {
    xkb_layout us,ru
    xkb_variant ,
    xkb_options grp:caps_toggle
    repeat_delay 300
    repeat_rate 50
}
input "0:0:Asus_WMI_hotkeys" {
    events enabled
    xkb_model "asus_laptop"
}

bindswitch --locked lid:on exec ~/.local/bin/lid-handler
bindswitch --locked lid:off exec sleep 2 && swaymsg output eDP-1 power on && swaymsg output eDP-1 enable


# Cursors
# set $cursor_theme "capitaine-cursors"
# set $cursor_theme "BreezeX-RosePineDawn-Linux"
set $cursor_theme "catppuccin-mocha-green-cursors"
set $cursor_size 32

seat seat0 xcursor_theme $cursor_theme $cursor_size
seat seat0 hide_cursor 5000
seat seat0 hide_cursor when-typing enable

exec_always {
    gsettings set org.gnome.desktop.interface cursor-theme $cursor_theme
    gsettings set org.gnome.desktop.interface cursor-size $cursor_size

    systemctl --user set-environment XCURSOR_THEME=$cursor_theme
    systemctl --user set-environment XCURSOR_SIZE=$cursor_size

    dbus-update-activation-environment --systemd XCURSOR_THEME XCURSOR_SIZE
}
