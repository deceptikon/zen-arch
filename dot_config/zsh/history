uptime -s
uptime -p | sed 's/up //'
uptime -p | sed 's/up //' | awk '\
{\
  # —Б–Њ–±—А–∞—В—Гђ (day/hour/minute -> –Ј–љ–∞—ГІ–µ–љ–Є–µ)\
  for (i=1; i<=NF; i++) {\
    if ($i ~ /^[0-9]+$/) {\
      v=$i+0; u=$(i+1);\
      if (u ~ /^day/) d=v;\
      else if (u ~ /^hour/) h=v;\
      else if (u ~ /^minute/) m=v;\
    }\
  }\
\
  # –њ—А–∞–≤–Є–ї–Њ: –µ—Б–ї–Є –µ—Б—В—Гђ –Љ–Є–љ—Г£—В—ГЂ, –≤—В–Њ—А–Њ–є –±–ї–Њ–Ї вАГі –ї–Є–±–Њ —ГІ–∞—Б—ГЂ, –ї–Є–±–Њ –і–љ–Є\
  if (m>0) {\
    if (h>0) printf "%dm || %dh\n", m, h;\
    else if (d>0) printf "%dm || %dd\n", m, d;\
    else printf "%dm\n", m;\
  } else {\
    # –µ—Б–ї–Є –Љ–Є–љ—Г£—В –љ–µ—В: –і–≤–∞ —Б–∞–Љ—ГЂ—Г• –Ї—А—Г£–њ–љ—ГЂ—Г• —Б—Г£—Г©–µ—Б—В–≤—Г£—ГЃ—Г©–Є—Г• –±–ї–Њ–Ї–∞ (–і–љ–Є –Є —ГІ–∞—Б—ГЂ)\
    if (d>0 && h>0) printf "%dd || %dh\n", d, h;\
    else if (d>0) printf "%dd\n", d;\
    else printf "%dh\n", h;\
  }\
}'\

uptime -p | sed 's/up //' | awk '\
{\
  d=h=m=0\
  if ($0 ~ /day/)    { match($0,/([0-9]+)[[:space:]]*day/,a); d=a[1]+0 }\
  if ($0 ~ /hour/)   { match($0,/([0-9]+)[[:space:]]*hour/,a); h=a[1]+0 }\
  if ($0 ~ /minute/) { match($0,/([0-9]+)[[:space:]]*min/,a); m=a[1]+0 }\
\
  totalMin = d*24*60 + h*60 + m\
  H = int(totalMin/60)\
  M = totalMin%60\
  printf "%dh %dm\n", H, M\
}'\

